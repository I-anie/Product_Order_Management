<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lumiera.shop.lumierashop.mapper.AdminOrderMapper">

    <sql id="findAllWhereCondition">
        <where>
            <if test="startDateTime != null">
                AND created_at &gt;= #{startDateTime}
            </if>
            <if test="endDateTime != null">
                AND created_at &lt; #{endDateTime}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="username != null and username != ''">
                AND username = #{username}
            </if>
            <choose>
                <when test="deleted">
                    AND deleted_at IS NOT NULL
                </when>
                <otherwise>
                    AND deleted_at IS NULL
                </otherwise>
            </choose>
        </where>
    </sql>

    <resultMap id="orderMap" type="OrderResponse">
        <id property="id" column="order_id"/>
        <result property="username" column="username"/>
        <result property="totalPrice" column="total_price"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>

        <collection property="orderItems" ofType="OrderItemResponse">
            <id property="id" column="order_item_id"/>
            <result property="productId" column="product_id"/>
            <result property="thumbnailUrl" column="thumbnail_url"/>
            <result property="name" column="name"/>
            <result property="price" column="price"/>
            <result property="quantity" column="quantity"/>
        </collection>
    </resultMap>

    <select id="findAll" resultType="Order">
        SELECT *
        FROM orders
        <include refid="findAllWhereCondition"/>
        ORDER BY
        <choose>
            <when test="deleted == true">
                deleted_at DESC, id DESC
            </when>
            <otherwise>
                id DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{limit}
    </select>

    <select id="findById" resultMap="orderMap">
        SELECT
        o.id AS order_id,
        o.username AS username,
        o.total_price AS total_price,
        o.status AS status,
        o.created_at AS created_at,
        o.updated_at AS updated_at,
        o.deleted_at AS deleted_at,
        oi.id AS order_item_id,
        oi.product_id AS product_id,
        oi.price AS price,
        oi.quantity AS quantity,
        p.thumbnail_url AS thumbnail_url,
        p.name AS name
        FROM orders o
        JOIN order_items oi ON o.id = oi.order_id
        JOIN products p ON oi.product_id = p.id
        WHERE o.id = #{orderId}
    </select>

    <select id="count">
        SELECT COUNT(*)
        FROM orders
        <include refid="findAllWhereCondition"/>
    </select>

    <update id="updateStatus">
        UPDATE orders
        SET status = 'PREPARING'
        <where>
            status = 'CONFIRMED'
            AND id IN
            <foreach collection="orderIds" item="orderId" open="(" separator="," close=")">
                #{orderId}
            </foreach>
        </where>
    </update>
</mapper>
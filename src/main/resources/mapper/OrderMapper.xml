<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lumiera.shop.lumierashop.mapper.OrderMapper">

    <sql id="findAllWhereCondition">
        <where>
            deleted_at IS NULL
            AND username = #{username}
            <if test="startDateTime != null">
                AND created_at &gt;= #{startDateTime}
            </if>
            <if test="endDateTime != null">
                AND created_at &lt; #{endDateTime}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <resultMap id="orderMap" type="OrderResponse">
        <id property="id" column="order_id"/>
        <result property="username" column="username"/>
        <result property="totalPrice" column="total_price"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>

        <collection property="orderItems" ofType="OrderItemResponse">
            <id property="id" column="order_item_id"/>
            <result property="productId" column="product_id"/>
            <result property="thumbnailUrl" column="thumbnail_url"/>
            <result property="name" column="name"/>
            <result property="price" column="price"/>
            <result property="quantity" column="quantity"/>
        </collection>
    </resultMap>

    <select id="findAllAndDeletedAtIsNull" resultType="Order">
        SELECT id, total_price, status, created_at
        FROM orders
        <include refid="findAllWhereCondition"/>
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (username, total_price)
        VALUES (#{order.username}, #{order.totalPrice})
    </insert>

    <select id="findByIdAndUsername" resultMap="orderMap">
        SELECT
        o.id AS order_id,
        o.username AS username,
        o.total_price AS total_price,
        o.status AS status,
        o.created_at AS created_at,
        oi.id AS order_item_id,
        oi.product_id AS product_id,
        oi.price AS price,
        oi.quantity AS quantity,
        p.thumbnail_url AS thumbnail_url,
        p.name AS name
        FROM orders o
        LEFT JOIN order_items oi ON o.id = oi.order_id
        LEFT JOIN products p ON oi.product_id = p.id
        WHERE o.id = #{orderId}
        AND o.username = #{username}
        AND o.deleted_at IS NULL
    </select>

    <select id="countAndDeletedAtIsNull" resultType="int">
        SELECT COUNT(*)
        FROM orders
        <include refid="findAllWhereCondition"/>
    </select>

    <update id="updateStatus">
        UPDATE orders
        SET status = 'CONFIRMED'
        WHERE id = #{orderId}
        AND username = #{username}
        AND status = 'PENDING'
    </update>
</mapper>